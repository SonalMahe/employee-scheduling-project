// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  EMPLOYER
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
}

enum Position {
  WAITER
  RUNNER
  HEAD_WAITER
  ADMIN
  CHEF
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AvailabilityStatus {
  AVAILABLE   // willing to work this shift
  UNAVAILABLE // cannot work this shift
  PREFERRED   // specifically wants this shift
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  loginCode String    @unique
  position  Position?
  role      Role
  photoUrl  String?
  createdAt DateTime  @default(now())
  employee  Employee?
}

model Employee {
  id              Int             @id @default(autoincrement())
  userId          Int             @unique
  user            User            @relation(fields: [userId], references: [id])
  availabilities  Availability[]
  scheduleEntries ScheduleEntry[]
}

model Shift {
  id              Int             @id @default(autoincrement())
  name            ShiftType       @unique
  availabilities  Availability[]
  scheduleEntries ScheduleEntry[]
}

model Availability {
  id         Int                @id @default(autoincrement())
  employeeId Int
  shiftId    Int
  dayOfWeek  DayOfWeek
  status     AvailabilityStatus @default(UNAVAILABLE)
  updatedAt  DateTime           @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id])

  // one record per employee + shift + day combo
  @@unique([employeeId, shiftId, dayOfWeek])
}

model ScheduleEntry {
  id         Int      @id @default(autoincrement())
  employeeId Int
  shiftId    Int
  date       DateTime @db.Date
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id])

  // one employee can only be assigned one shift per day
  @@unique([employeeId, date])
}
